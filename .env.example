# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
# Ambiente da aplicação. Aceita: 'development', 'production', 'test'
NODE_ENV=development

# Porta onde o servidor Fastify irá rodar
PORT=3333

# Endereço de host (0.0.0.0 para aceitar conexões externas, 127.0.0.1 para local)
HOST=0.0.0.0

# ==============================================================================
# LOGS CONFIGURATION (Pino + Pino-Roll)
# ==============================================================================
# Nível mínimo de logs a serem exibidos no console e processados.
# Opções: 'trace', 'debug', 'info', 'notice', 'warn', 'error', 'critical', 'alert', 'emergency', 'fatal', 'all', 'off'
LOG_LEVEL=info

# Níveis que gerarão arquivos de log persistentes separados (separados por vírgula).
# Cada nível aqui cria um arquivo: logs/server-{level}.log
# Exemplo: info,warn,error
LOG_LEVELS_FILES=info,warn,error

# Tamanho máximo de cada arquivo de log antes de rotacionar.
# Formato: número seguido de 'k' (kb), 'm' (mb) ou 'g' (gb). Ex: 10m, 100k, 1g
LOG_ROTATION_SIZE=10m

# Intervalo de tempo para rotação forçada de arquivo.
# Formato: número seguido de 'h' (horas) ou 'd' (dias). Ex: 12h, 1d, 7d
LOG_ROTATION_INTERVAL=1d

# Quantidade total de arquivos antigos (histórico) a serem mantidos no disco por nível.
# Após esse número, os arquivos mais antigos são deletados automaticamente.
LOG_KEEP_COUNT=7
